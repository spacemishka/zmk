#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            label = "Numpad";
            bindings = <
                &kp KP_N7   &kp KP_N8   &kp KP_N9   &kp KP_SLASH   &none
                &kp KP_N4   &kp KP_N5   &kp KP_N6   &kp KP_ASTERISK &none
                &kp KP_N1   &kp KP_N2   &kp KP_N3   &kp KP_MINUS   &none
                &kp KP_N0   &kp KP_DOT  &kp KP_ENTER &kp KP_PLUS   &none
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };
    };
};
